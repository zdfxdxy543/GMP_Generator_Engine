{
  "requirement": "机器人位置控制，要求低纹波和快速响应",
  "scenario": "robotics",
  "control_mode": "position",
  "layers": [
    {
      "name": "trajectory",
      "module": "ctl_step_ramp_generator",
      "params": {
        "jerk_limit": 0.1
      }
    },
    {
      "name": "mech",
      "module": "ctl_step_vel_pos_ctrl",
      "params": {
        "kp": 2.0,
        "ki": 1.0
      }
    },
    {
      "name": "distributor",
      "module": "ctl_step_spm_fw_distributor",
      "params": {
        "id_ref": 0.0
      }
    },
    {
      "name": "current",
      "module": "ctl_step_foc_core",
      "params": {
        "kp": 2.0,
        "ki": 100.0
      }
    },
    {
      "name": "observer",
      "module": "ctl_step_spd_calculator",
      "params": {
        "lpf_bw": 30.0
      }
    }
  ]
}